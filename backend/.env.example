# Puerto del servidor (opcional)
PORT=3000

# OAuth 2.0 — Client ID de Google Cloud Console (tipo "Aplicación web")
# Orígenes autorizados: http://localhost:3000
# Déjalo vacío para usar el modo demo, o configura en http://localhost:3000/configurar-google.html
GOOGLE_CLIENT_ID=

# Modo demo: botón Google funciona sin Client ID (cuentas de prueba)
ALLOW_DEMO_GOOGLE=true

# Permite guardar el Client ID desde configurar-google.html
ALLOW_SETUP=true

# reCAPTCHA v2 — https://www.google.com/recaptcha/admin (tipo "Casilla de verificación v2")
# Dominio: localhost | Orígenes: http://localhost:3000
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_ENABLED=true
