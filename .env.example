# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_with_min_32_chars
JWT_EXPIRATION=7d

# Database
DATABASE_URL=./data/consultorio.db

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-from-google
SMTP_FROM_NAME=Consultorio Odontológico
SMTP_FROM_EMAIL=your-email@gmail.com

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRATION=15m
PASSWORD_RESET_TOKEN_SECRET=your_password_reset_secret_change_this

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
